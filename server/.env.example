PORT=3001
JWT_SECRET=your-secret-key-change-this-in-production
NODE_ENV=development
# Comma-separated extra hostnames added to the TLS cert SAN (e.g. Tailscale machine name).
SERVER_HOSTNAMES=lister

# Bus timetable (UK Bus Open Data Service — free, no API key required).
# Defaults to the South East England regional GTFS feed. Change the region
# segment of the URL to match where your stop is, e.g. .../gtfs-file/london/
BODS_GTFS_URL=https://data.bus-data.dft.gov.uk/timetable/download/gtfs-file/south_east/
# Days of departures to pre-compute into the local index.
BUS_HORIZON_DAYS=8
# How often (hours) to rebuild the index from the feed.
BUS_REFRESH_INTERVAL_HOURS=24
# IANA timezone used to interpret schedule times and "now".
BUS_TIMEZONE=Europe/London
